---
interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  items: Crumb[];
}
const { items } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: items.map((item, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: item.label,
    ...(item.href && { item: new URL(item.href, Astro.site).toString() }),
  })),
};
---

<nav aria-label="Breadcrumb" class="text-sm text-[#9CA3AF] mb-6">
  <ol class="flex flex-wrap items-center gap-2 list-none m-0 p-0">
    {
      items.map((item, i) => (
        <li class="flex items-center gap-2">
          {item.href ? (
            <a href={item.href} class="hover:text-[#3B82F6] no-underline">
              {item.label}
            </a>
          ) : (
            <span class="text-[#1E293B] font-medium">{item.label}</span>
          )}
          {i < items.length - 1 && <span>/</span>}
        </li>
      ))
    }
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline />
