---
// Cross-linking CTA for baby articles → pregnancy.chparenting.com
import { siteConfig } from "../../site.config";
---

<div class="my-10 rounded-2xl overflow-hidden bg-gradient-to-r from-pink-50 to-rose-50 border border-pink-100">
  <div class="p-6 md:p-8 flex flex-col md:flex-row items-center gap-6">
    <div class="text-5xl shrink-0">🤰</div>
    <div class="flex-1 text-center md:text-left">
      <p class="text-lg font-display font-semibold text-[#BE185D] mb-1">
        Planning baby #2? Visit our pregnancy guide.
      </p>
      <p class="text-sm text-[#1E293B]/70 mb-4">
        Due date calculators, week-by-week tracking, weight gain guides, and
        expert articles for every trimester of your pregnancy journey.
      </p>
      <a
        href={siteConfig.sister.pregnancy}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#BE185D] text-white font-semibold rounded-full no-underline hover:bg-pink-700 transition text-sm"
      >
        Visit Pregnancy Guide
        <span>→</span>
      </a>
    </div>
  </div>
</div>
