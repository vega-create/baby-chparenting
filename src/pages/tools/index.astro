---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ToolCard from "../../components/ToolCard.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";

const tools = [
  {
    icon: "😴",
    title: "Sleep Tracker",
    description: "Track naps, nighttime sleep, and build healthy sleep routines by age.",
    href: "/tools/sleep-tracker/",
  },
  {
    icon: "🍼",
    title: "Feeding Timer",
    description: "Time breastfeeding sessions, bottle feeds, and track daily intake.",
    href: "/tools/feeding-timer/",
  },
  {
    icon: "📊",
    title: "Growth Calculator",
    description: "Plot your baby's weight and length on WHO growth percentile charts.",
    href: "/tools/growth-calculator/",
  },
  {
    icon: "👶",
    title: "Name Generator",
    description: "Discover the perfect baby name with meanings, origins, and popularity.",
    href: "/tools/name-generator/",
  },
  {
    icon: "🏆",
    title: "Milestone Tracker",
    description: "Track developmental milestones from newborn to 24 months.",
    href: "/tools/milestone-checker/",
  },
  {
    icon: "📏",
    title: "Diaper Size Guide",
    description: "Find the right diaper size by weight and age with brand comparisons.",
    href: "/tools/",
  },
  {
    icon: "🌡️",
    title: "Fever Guide",
    description: "Age-appropriate temperature ranges and when to call the doctor.",
    href: "/tools/",
  },
  {
    icon: "🥣",
    title: "Solids Introduction Guide",
    description: "Stage-by-stage guide to introducing solid foods safely.",
    href: "/tools/",
  },
];
---

<BaseLayout
  title="Free Baby Care Tools"
  description="Free baby care tools: sleep tracker, feeding timer, growth charts, name generator, milestone tracker, and more."
>
  <section class="max-w-6xl mx-auto px-4 py-10">
    <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Tools" }]} />
    <h1 class="mb-3">Free baby care tools</h1>
    <p class="text-lg text-[#9CA3AF] mb-10 max-w-2xl">
      Evidence-based tools and trackers to support you through every stage
      of your baby's first years.
    </p>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {tools.map((t) => <ToolCard {...t} />)}
    </div>
  </section>
</BaseLayout>
