---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ToolCard from "../../components/ToolCard.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";

const tools = [
  {
    icon: "😴",
    title: "Sleep Tracker",
    description: "Track naps, nighttime sleep, and build healthy sleep routines by age.",
    href: "/tools/sleep-tracker/",
  },
  {
    icon: "🌙",
    title: "White Noise Generator",
    description: "Play soothing white noise, rain, heartbeat, and more to help baby sleep.",
    href: "/tools/white-noise/",
  },
  {
    icon: "🛏️",
    title: "Bedtime Calculator",
    description: "Calculate the ideal bedtime based on baby's age and wake-up time.",
    href: "/tools/bedtime-calculator/",
  },
  {
    icon: "🍼",
    title: "Feeding Timer",
    description: "Time breastfeeding sessions, bottle feeds, and track daily intake.",
    href: "/tools/feeding-timer/",
  },
  {
    icon: "🧮",
    title: "Bottle Calculator",
    description: "Calculate how much formula or breast milk baby needs per bottle and per day.",
    href: "/tools/bottle-calculator/",
  },
  {
    icon: "🥣",
    title: "Solids Readiness Quiz",
    description: "Interactive quiz to check if your baby is ready for solid foods.",
    href: "/tools/solids-readiness/",
  },
  {
    icon: "📊",
    title: "Growth Calculator",
    description: "Plot your baby's weight and length on WHO growth percentile charts.",
    href: "/tools/growth-calculator/",
  },
  {
    icon: "👶",
    title: "Name Generator",
    description: "Discover the perfect baby name with meanings, origins, and popularity.",
    href: "/tools/name-generator/",
  },
  {
    icon: "👫",
    title: "Sibling Name Matcher",
    description: "Find names that pair perfectly with your existing child's name.",
    href: "/tools/sibling-names/",
  },
  {
    icon: "📈",
    title: "Name Popularity Trends",
    description: "Search a name and see its popularity over time with decade-level trends.",
    href: "/tools/name-trends/",
  },
  {
    icon: "🏆",
    title: "Milestone Tracker",
    description: "Track developmental milestones from newborn to 24 months.",
    href: "/tools/milestone-checker/",
  },
  {
    icon: "📏",
    title: "Diaper Size Guide",
    description: "Find the right diaper size by weight with cost estimates and type comparisons.",
    href: "/tools/diaper-size/",
  },
  {
    icon: "🚗",
    title: "Car Seat Finder",
    description: "Find the right car seat type based on age, weight, and height with safety tips.",
    href: "/tools/car-seat-finder/",
  },
  {
    icon: "💪",
    title: "Tummy Time Tracker",
    description: "Track daily tummy time sessions with timer, progress ring, and 7-day history.",
    href: "/tools/tummy-time/",
  },
  {
    icon: "🗣️",
    title: "Language Milestone Quiz",
    description: "Check baby's language development with age-appropriate milestone checklists.",
    href: "/tools/language-quiz/",
  },
  {
    icon: "🌡️",
    title: "Fever Guide",
    description: "Age-appropriate temperature ranges and when to call the doctor.",
    href: "/tools/",
  },
];
---

<BaseLayout
  title="Free Baby Care Tools"
  description="Free baby care tools: sleep tracker, feeding timer, growth charts, name generator, milestone tracker, and more."
>
  <section class="max-w-6xl mx-auto px-4 py-10">
    <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Tools" }]} />
    <h1 class="mb-3">Free baby care tools</h1>
    <p class="text-lg text-[#9CA3AF] mb-10 max-w-2xl">
      Evidence-based tools and trackers to support you through every stage
      of your baby's first years.
    </p>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {tools.map((t) => <ToolCard {...t} />)}
    </div>
  </section>
</BaseLayout>
