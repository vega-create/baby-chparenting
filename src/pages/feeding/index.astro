---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { getCollection } from "astro:content";

const now = new Date();
const allPosts = await getCollection("blog", ({ data }) => !data.draft && data.publishDate <= now && data.category === "feeding");
const posts = allPosts.sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);
---

<BaseLayout
  title="Baby Feeding Guides"
  description="Expert guides on breastfeeding, formula feeding, introducing solids, and baby nutrition."
>
  <section class="max-w-5xl mx-auto px-4 py-10">
    <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Feeding" }]} />
    <h1 class="mb-3">🍼 Baby Feeding Guides</h1>
    <p class="text-lg text-[#9CA3AF] mb-10 max-w-2xl">
      From breastfeeding basics to introducing solids — research-backed
      guidance for every feeding stage of your baby's first years.
    </p>

    {posts.length > 0 ? (
      <div class="grid gap-6 md:grid-cols-2">
        {posts.map((post) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description || ""}
            category={post.data.category || ""}
            href={`/blog/${post.data.slug}/`}
            image={post.data.image}
          />
        ))}
      </div>
    ) : (
      <div class="card text-center py-16">
        <p class="text-4xl mb-3">🍼</p>
        <p class="text-[#1E293B] font-medium mb-2">Feeding articles coming soon</p>
        <p class="text-sm text-[#9CA3AF] mb-5">
          We're writing expert guides on breastfeeding, formula, and solids.
        </p>
        <a href="/blog/" class="btn-primary">Browse all articles</a>
      </div>
    )}
  </section>
</BaseLayout>
