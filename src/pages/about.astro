---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
---

<BaseLayout
  title="About"
  description="About Baby Care Guide — free baby care tools and evidence-based articles for new parents."
>
  <section class="max-w-3xl mx-auto px-4 py-10">
    <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "About" }]} />
    <h1 class="mb-6">About Baby Care Guide</h1>
    <div class="card prose prose-blue max-w-none">
      <p class="leading-relaxed mb-4">
        Baby Care Guide exists to make parenting less overwhelming and more
        enjoyable. We build free, evidence-based tools and write expert
        articles that meet you exactly where you are in your parenting journey.
      </p>
      <p class="leading-relaxed mb-4">
        Our content is informed by trusted sources including the American
        Academy of Pediatrics (AAP), the World Health Organization (WHO),
        and leading pediatric research institutions.
      </p>
      <p class="leading-relaxed mb-4">
        Every article is written by certified professionals — pediatric sleep
        consultants, lactation consultants, and pediatricians — and medically
        reviewed before publication.
      </p>
      <p class="leading-relaxed text-sm text-[#9CA3AF] italic">
        Baby Care Guide is a sister site of chparenting.com and pregnancy.chparenting.com.
      </p>
    </div>
  </section>
</BaseLayout>
