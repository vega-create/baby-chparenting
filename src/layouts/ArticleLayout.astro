---
import BaseLayout from "./BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import TableOfContents from "../components/TableOfContents.astro";
import AuthorBox from "../components/AuthorBox.astro";
import PregnancySiteCTA from "../components/PregnancySiteCTA.astro";
import EditorialNotice from "../components/EditorialNotice.astro";
import ArticleByline from "../components/ArticleByline.astro";
import RelatedArticles from "../components/RelatedArticles.astro";

interface Props {
  title: string;
  description?: string;
  publishDate: Date;
  lastReviewed?: Date;
  category?: string;
  tags?: string[];
  author?: string;
  authorUrl?: string;
  image?: string;
  imageCredit?: string;
  headings: { depth: number; slug: string; text: string }[];
  slug: string;
}

const {
  title,
  description,
  publishDate,
  lastReviewed,
  category,
  tags = [],
  author = "Vega Lin",
  authorUrl = "/author/vega-lin/",
  image,
  imageCredit,
  headings,
  slug,
} = Astro.props;

const categoryLabels: Record<string, string> = {
  sleep: "Sleep",
  names: "Names",
  feeding: "Feeding",
  gear: "Gear",
  development: "Development",
};

const canonicalUrl = `https://baby.chparenting.com/blog/${slug}/`;

// Article JSON-LD for E-E-A-T
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description: description,
  image: image ? [image] : undefined,
  datePublished: publishDate.toISOString(),
  dateModified: (lastReviewed || publishDate).toISOString(),
  author: {
    "@type": "Person",
    name: author,
    url: `https://baby.chparenting.com${authorUrl}`,
  },
  publisher: {
    "@type": "Organization",
    name: "Baby Care Guide",
    logo: {
      "@type": "ImageObject",
      url: "https://baby.chparenting.com/favicon.svg",
    },
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonicalUrl,
  },
};
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  type="article"
  publishDate={publishDate.toISOString()}
  author={author}
  canonical={canonicalUrl}
>
  <article class="max-w-6xl mx-auto px-4 py-10">
    <Breadcrumb
      items={[
        { label: "Home", href: "/" },
        { label: "Blog", href: "/blog/" },
        ...(category
          ? [
              {
                label: categoryLabels[category] ?? category,
                href: `/blog/?category=${category}`,
              },
            ]
          : []),
        { label: title },
      ]}
    />

    <header class="mb-8 max-w-3xl">
      {
        category && (
          <span class="inline-block text-xs font-semibold uppercase tracking-wide text-[#1D4ED8] bg-blue-50 px-3 py-1 rounded-full mb-4">
            {categoryLabels[category] ?? category}
          </span>
        )
      }
      {
        image && (
          <figure class="mb-6">
            <img
              src={image}
              alt={title}
              class="w-full rounded-2xl max-h-[400px] object-cover object-top"
              loading="eager"
            />
            {imageCredit && (
              <figcaption class="mt-2 text-xs text-[#9CA3AF] italic">
                Photo: {imageCredit}
              </figcaption>
            )}
          </figure>
        )
      }
      <h1 class="mb-4">{title}</h1>
      <ArticleByline
        author={author}
        authorUrl={authorUrl}
        publishDate={publishDate}
        lastReviewed={lastReviewed}
        tags={tags}
      />
    </header>

    <div class="lg:grid lg:grid-cols-[1fr_250px] lg:gap-12">
      <div class="article-content">
        <EditorialNotice />

        <slot />

        <div
          class="mt-12 p-4 bg-amber-50 border-l-4 border-amber-300 rounded-r-xl text-sm text-[#1E293B] italic"
        >
          <strong>Medical Disclaimer:</strong> This article is for informational
          purposes only and is not a substitute for professional medical advice,
          diagnosis, or treatment. Always consult your pediatrician or
          healthcare provider with any questions about your baby's health.
        </div>

        <AuthorBox name={author} url={authorUrl} />

        <RelatedArticles category={category} currentSlug={slug} limit={3} />

        <PregnancySiteCTA />
      </div>

      <aside class="hidden lg:block">
        <TableOfContents headings={headings} />
      </aside>
    </div>

    <div class="lg:hidden -mt-6 mb-6">
      <TableOfContents headings={headings} />
    </div>
  </article>

  <script
    type="application/ld+json"
    set:html={JSON.stringify(articleSchema)}
    is:inline
  />
</BaseLayout>
